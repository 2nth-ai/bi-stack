# ------------------------------------------------------------------------------
# bi-stack — local dev environment
# Copy this file to `.env` and fill in the values.
#
# Neon paid account: imbilawork@gmail.com
# Project:  bi-stack
# Region:   aws-eu-central-1 (Frankfurt — closest to africa-south1 in 2026)
# Branches: main (prod), dev (local)
# Schemas:  superset_meta, analytics
# ------------------------------------------------------------------------------

# --- Superset metadata DB (Neon dev branch, DIRECT/unpooled endpoint) ---
# Unpooled is mandatory — Neon's pooled endpoint breaks SQLAlchemy prepared statements.
# Format: postgresql+psycopg2://<user>:<pass>@ep-xxxx.eu-central-1.aws.neon.tech/<db>?sslmode=require
SUPERSET_METADATA_DB_URI=postgresql+psycopg2://user:pass@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require&options=-csearch_path%3Dsuperset_meta

# --- Analytics warehouse (same Neon dev branch, analytics schema) ---
# Registered in Superset UI as an additional database; dbt also writes here.
ANALYTICS_DB_URI=postgresql://user:pass@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# --- dbt pooled endpoint (short-lived connections — pooled is fine) ---
NEON_POOLED_URI=postgresql://user:pass@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require

# --- Redis (local Docker Compose; Upstash URL in prod) ---
REDIS_URL=redis://redis:6379/0

# --- Superset secrets ---
# Generate: openssl rand -base64 42
SUPERSET_SECRET_KEY=CHANGE_ME_openssl_rand_base64_42
# Generate: openssl rand -base64 42 (12-month rotation — see docs/runbook.md)
GUEST_TOKEN_JWT_SECRET=CHANGE_ME_guest_token_signer

# --- Superset admin bootstrap (created once by bootstrap.sh) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME
ADMIN_EMAIL=imbilawork@gmail.com
ADMIN_FIRSTNAME=Craig
ADMIN_LASTNAME=Leppan

# --- Optional: Mapbox for geo charts ---
MAPBOX_API_KEY=
